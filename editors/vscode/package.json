{
  "name": "drenv-lsp",
  "displayName": "drenv",
  "description": "DragonRuby language intelligence via the drenv language server.",
  "version": "0.1.1",
  "publisher": "nitemaeric",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nitemaeric/drenv"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "dragonruby",
    "ruby",
    "lsp",
    "gamedev"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onLanguage:ruby",
    "onLanguage:toml"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --sourcemap --watch",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
