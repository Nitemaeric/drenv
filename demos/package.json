{
  "name": "drenv-demos",
  "version": "0.0.0",
  "private": true,
  "description": "Branded demo videos for drenv, built with Remotion.",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render:quickstart": "remotion render src/index.ts QuickStart out/quick-start.mp4",
    "render:dependencies": "remotion render src/index.ts Dependencies out/dependencies.mp4",
    "render:tiers": "remotion render src/index.ts Tiers out/tiers.mp4",
    "render": "npm run render:quickstart && npm run render:dependencies && npm run render:tiers",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.4.5"
  }
}
